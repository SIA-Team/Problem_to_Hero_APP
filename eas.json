{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": false
      }
    },
    "development-adhoc": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": false,
        "enterpriseProvisioning": "adhoc"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "production-apk": {
      "distribution": "internal",
      "channel": "production",
      "android": {
        "buildType": "apk",
        "autoIncrement": true,
        "credentialsSource": "local"
      },
      "ios": {
        "autoIncrement": true
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "autoIncrement": true
      },
      "ios": {
        "simulator": false,
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6762328037",
        "appleTeamId": "RQ66NFT7M5",
        "bundleIdentifier": "com.problemvshero.app"
      }
    }
  }
}
