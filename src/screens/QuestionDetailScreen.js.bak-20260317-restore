                    </TouchableOpacity>
                    <TouchableOpacity style={styles.supplementAction}>
                      <Ionicons name="chatbubble-outline" size={16} color="#666" />
                      <Text style={styles.supplementActionText}>{supplement.comments}</Text>
                    </TouchableOpacity>
                  </View>
                </View>
              ))}
            </View>
          )}
        </ScrollView>
        
        {/* 底部操作栏 */}
        <View style={styles.bottomBar}>
          <TouchableOpacity 
            style={styles.bottomAction}
            onPress={() => setShowWriteCommentModal(true)}
          >
            <Ionicons name="chatbubble-outline" size={24} color="#666" />
            <Text style={styles.bottomActionText}>评论</Text>
          </TouchableOpacity>
          
          <TouchableOpacity style={styles.bottomAction}>
            <Ionicons name="heart-outline" size={24} color="#666" />
            <Text style={styles.bottomActionText}>点赞</Text>
          </TouchableOpacity>
          
          <TouchableOpacity style={styles.bottomAction}>
            <Ionicons name="bookmark-outline" size={24} color="#666" />
            <Text style={styles.bottomActionText}>收藏</Text>
          </TouchableOpacity>
          
          <TouchableOpacity style={styles.bottomAction}>
            <Ionicons name="share-outline" size={24} color="#666" />
            <Text style={styles.bottomActionText}>分享</Text>
          </TouchableOpacity>
        </View>
      </Animated.View>
      
      {/* 写评论弹窗 */}
      <WriteCommentModal
        visible={showWriteCommentModal}
        onClose={() => setShowWriteCommentModal(false)}
        onPublish={handleCommentPublished}
        targetType={1}
        targetId={questionId}
        parentId={0}
      />
    </SafeAreaView>
  );
