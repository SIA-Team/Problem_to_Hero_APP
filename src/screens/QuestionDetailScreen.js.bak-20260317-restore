              <Text style={[styles.tabText, activeTab === 'supplements' && styles.activeTabText]}>
                补充 ({supplementQuestions.length})
              </Text>
            </TouchableOpacity>
          </View>
          
          {/* 内容区域 */}
          {activeTab === 'answers' && (
            <View style={styles.answersContainer}>
              {answers.map((answer, index) => (
                <View key={answer.id} style={styles.answerItem}>
                  <View style={styles.answerHeader}>
                    <Avatar source={{ uri: answer.avatar }} size={40} />
                    <View style={styles.answerAuthorInfo}>
                      <View style={styles.answerAuthorRow}>
                        <Text style={styles.answerAuthor}>{answer.author}</Text>
                        {answer.verified && (
                          <Ionicons name="checkmark-circle" size={16} color="#007AFF" />
