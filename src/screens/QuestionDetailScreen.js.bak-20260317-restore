    if (!questionId) return;
    
    try {
      console.log('🔄 Loading comments:', { questionId, sortBy, pageNum, isRefresh, isLoadMore });
      
      if (isRefresh) {
        setCommentsRefreshing(true);
      } else if (isLoadMore) {
        setCommentsLoadingMore(true);
      } else {
        setCommentsLoading(true);
      }
      
      const params = {
        targetType: 1,
        targetId: parseInt(questionId),
        parentId: 0,
        sortBy: sortBy,
        pageNum: pageNum,
        pageSize: 10
      };
      
      console.log('📤 Comment API request params:', params);
      
      const response = await commentApi.getComments(params);
      console.log('📥 Comment API response:', response);
      
      if (response && response.data) {
        const { list = [], total = 0 } = response.data;
        const hasMore = list.length >= 10; // 如果返回的数据等于pageSize，说明可能还有更多数据
        
        console.log('📊 Comment data processed:', { 
          listLength: list.length, 
          total, 
          hasMore, 
          sortBy, 
          pageNum 
        });
        
        setCommentsCache(prev => {
          const newCache = { ...prev };
          
          if (isRefresh || pageNum === 1) {
            // 刷新或首次加载，替换数据
            newCache[sortBy] = {
              list: list,
              total: total,
              pageNum: pageNum,
              hasMore: hasMore,
              loaded: true,
              lastUpdated: Date.now()
            };
          } else {
            // 加载更多，追加数据
            const existingList = newCache[sortBy].list || [];
            newCache[sortBy] = {
              ...newCache[sortBy],
              list: [...existingList, ...list],
              pageNum: pageNum,
              hasMore: hasMore,
              lastUpdated: Date.now()
            };
          }
          
          return newCache;
        });
        
        console.log('✅ Comments loaded successfully');
      } else {
        console.warn('⚠️ Invalid comment response format:', response);
      }
    } catch (error) {
      console.error('❌ Failed to load comments:', error);
      showToast('加载评论失败');
