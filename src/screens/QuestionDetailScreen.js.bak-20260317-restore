                      <Ionicons name="share-outline" size={20} color="#666" />
                      <Text style={styles.answerActionText}>分享</Text>
                    </TouchableOpacity>
                  </View>
                </View>
              ))}
            </View>
          )}
          
          {activeTab === 'comments' && renderCommentsList()}
          
          {activeTab === 'supplements' && (
            <View style={styles.supplementsContainer}>
              {supplementQuestions.map((supplement, index) => (
                <View key={supplement.id} style={styles.supplementItem}>
                  <View style={styles.supplementHeader}>
                    <Avatar source={{ uri: supplement.avatar }} size={32} />
